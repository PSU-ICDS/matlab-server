<%-
  slurm_args = [
    "--mem=#{global_memory}G",
    "--cpus-per-task=#{global_cores}"
  ]
-%>

<%- sbatch_args = global_advanced == "1" ? global_sbatch_options.to_s.split("\n").flat_map { |arg| arg.split } : [] %>
<% slurm_args.concat(sbatch_args) %>

batch_connect:
  template: "basic"
script:
  native:
    <%- slurm_args.each do |arg| %>
      - "<%= arg %>"
    <%- end %>
